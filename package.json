{
  "name": "@cernion/openclaw-energy-sidecar",
  "version": "0.1.0",
  "description": "OpenClaw plugin for generic Energy Sidecar providers, with Cernion as the first provider.",
  "type": "module",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SmartEnergySolutions/cernion-openclaw-sidecar.git"
  },
  "bugs": {
    "url": "https://github.com/SmartEnergySolutions/cernion-openclaw-sidecar/issues"
  },
  "homepage": "https://github.com/SmartEnergySolutions/cernion-openclaw-sidecar#readme",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "plugin:build": "npm run build && openclaw plugins build --entry ./dist/index.js",
    "plugin:validate": "npm run build && openclaw plugins validate --entry ./dist/index.js",
    "test": "vitest run",
    "test:integration": "npm run build && node scripts/sidecar-smoke.mjs"
  },
  "files": [
    "dist",
    "scripts",
    "docker",
    "openclaw.plugin.json",
    "README.md"
  ],
  "peerDependencies": {
    "openclaw": ">=2026.5.17"
  },
  "dependencies": {
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "openclaw": "latest",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
